{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["opencode-sddu-plugin"],
  "agent": {
    "sddu": {
      "description": "SDDU Master Coordinator - 智能路由助手",
      "model": "bailian/qwen3.5-plus",
      "prompt": "{file:.opencode/agents/sddu.md}"
    },
    "sddu-help": {
      "description": "SDDU Help Assistant - 使用指南",
      "model": "bailian/qwen3.5-plus",
      "prompt": "{file:.opencode/agents/sddu-help.md}"
    },
    "sddu-discovery": {
      "description": "SDDU 需求挖掘专家 (阶段 0/6)",
      "model": "bailian/qwen3.5-plus",
      "prompt": "{file:.opencode/agents/sddu-discovery.md}"
    },
    "sddu-0-discovery": {
      "description": "SDDU 需求挖掘 (长名 0/6)",
      "model": "bailian/qwen3.5-plus",
      "prompt": "{file:.opencode/agents/sddu-discovery.md}"
    },
    "sddu-1-spec": {
      "description": "SDDU 规范编写专家 (阶段 1/6)",
      "model": "bailian/qwen3.5-plus",
      "prompt": "{file:.opencode/agents/sddu-spec.md}"
    },
    "sddu-2-plan": {
      "description": "SDDU 技术规划专家 (阶段 2/6)",
      "model": "bailian/qwen3.5-plus",
      "prompt": "{file:.opencode/agents/sddu-plan.md}"
    },
    "sddu-3-tasks": {
      "description": "SDDU 任务分解专家 (阶段 3/6)",
      "model": "bailian/qwen3.5-plus",
      "prompt": "{file:.opencode/agents/sddu-tasks.md}"
    },
    "sddu-4-build": {
      "description": "SDDU 任务实现专家 (阶段 4/6)",
      "model": "bailian/qwen3-coder-plus",
      "prompt": "{file:.opencode/agents/sddu-build.md}"
    },
    "sddu-5-review": {
      "description": "SDDU 代码审查专家 (阶段 5/6)",
      "model": "bailian/qwen3-coder-plus",
      "prompt": "{file:.opencode/agents/sddu-review.md}"
    },
    "sddu-6-validate": {
      "description": "SDDU 验证专家 (阶段 6/6)",
      "model": "bailian/qwen3-coder-plus",
      "prompt": "{file:.opencode/agents/sddu-validate.md}"
    },
    "sddu-roadmap": {
      "description": "SDDU Roadmap 规划专家 - 多版本路线图规划",
      "model": "bailian/qwen3.5-plus",
      "prompt": "{file:.opencode/agents/sddu-roadmap.md}"
    },
    "sddu-docs": {
      "description": "SDDU 目录导航生成器 - 扫描目录结构生成 README 导航",
      "model": "bailian/qwen3.5-plus",
      "prompt": "{file:.opencode/agents/sddu-docs.md}"
    }
  },
  "permission": {
    "*": "allow",
    "read": {
      "*": "allow",
      "*.env": "ask",
      "*.env.*": "ask"
    },
    "edit": "allow",
    "bash": {
      "*": "ask",
      "git *": "allow",
      "npm *": "allow",
      "yarn *": "allow",
      "pnpm *": "allow",
      "grep *": "allow",
      "ls *": "allow",
      "cat *": "allow",
      "mkdir *": "allow",
      "touch *": "allow",
      "rm *": "ask",
      "node *": "allow"
    },
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "task": "allow",
    "skill": "allow",
    "question": "allow",
    "webfetch": "allow",
    "external_directory": "ask"
  }
}