{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "node",
    "lib": ["ES2022"],
    "declaration": true,
    "strict": false,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": ".",
    "paths": {
      "@opencode-ai/plugin": ["./.opencode/node_modules/@opencode-ai/plugin/dist/index.js"],
      "@opencode-ai/plugin/*": ["./.opencode/node_modules/@opencode-ai/plugin/dist/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", ".opencode"]
}
