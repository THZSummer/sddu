{
  "name": "opencode-sddu-plugin",
  "version": "1.1.0",
  "description": "Specification-Driven Development Ultimate plugin for OpenCode",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "npm run build:agents && npm run build:ts",
    "build:agents": "node build-agents.cjs",
    "build:ts": "tsc",
    "dev": "tsc --watch",
    "clean": "rimraf dist",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:unit": "node --test 'dist/**/*.test.js'",
    "test:state:integration": "node --test 'dist/state/agent-integration.test.js'",
    "sddu-spec": "node ./dist/commands/sdd-spec.js",
    "sddu-plan": "node ./dist/commands/sdd-plan.js",
    "sddu-tasks": "node ./dist/commands/sdd-tasks.js",
    "sddu-build": "node ./dist/commands/sdd-build.js",
    "sddu-review": "node ./dist/commands/sdd-review.js",
    "sddu-validate": "node ./dist/commands/sdd-validate.js",
    "sddu-docs": "node ./dist/commands/sdd-docs.js",
    "sddu-roadmap": "node ./dist/commands/sdd-roadmap.js",
    "sddu-help": "node ./dist/commands/sdd-help.js",
    "sdd-spec": "node ./dist/commands/sdd-spec.js",
    "sdd-plan": "node ./dist/commands/sdd-plan.js",
    "sdd-tasks": "node ./dist/commands/sdd-tasks.js",
    "sdd-build": "node ./dist/commands/sdd-build.js",
    "sdd-review": "node ./dist/commands/sdd-review.js",
    "sdd-validate": "node ./dist/commands/sdd-validate.js",
    "sdd-docs": "node ./dist/commands/sdd-docs.js",
    "sdd-roadmap": "node ./dist/commands/sdd-roadmap.js",
    "sdd-help": "node ./dist/commands/sdd-help.js",
    "prepackage": "npm run build",
    "package": "node scripts/package.cjs",
    "postpackage": "echo 'Packaging complete. Files are in dist/sdd/ and dist/sdd.zip'"
  },
  "keywords": [
    "opencode",
    "plugin",
    "sdd",
    "sddu"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "archiver": "^7.0.1",
    "fs-extra": "^11.3.4",
    "jest": "^30.3.0",
    "rimraf": "^5.0.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "uuid": "^13.0.0"
  },
  "files": [
    "dist/sddu/**/*",
    "dist/sdd/**/*",
    "src/**/*",
    "!.opencode",
    "!.sdd",
    "README.md",
    "LICENSE"
  ]
}
